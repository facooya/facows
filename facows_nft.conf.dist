add table inet facows;
delete table inet facows;

table inet facows {
	set facows_black {
		type ipv4_addr;
		flags timeout;
	}

	set facows_black6 {
		type ipv6_addr;
		flags timeout;
	}

	chain facows_input {
		type filter hook input priority filter; policy drop;
		ip saddr @facows_black drop;
		ip6 saddr @facows_black6 drop;

		iif "lo" accept;
		ct state established,related accept;

		tcp dport %d accept;
		# tcp dport [PORT] accept;
	}
}
